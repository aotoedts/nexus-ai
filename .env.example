# ==========================================
# NEXUS AI - Variaveis de Ambiente (exemplo)
# ==========================================

# --- Geral ---
NODE_ENV=development
APP_NAME=Nexus AI

# --- Backend ---
PORT=3333
HOST=0.0.0.0
API_PREFIX=/api/v1
# Origens permitidas (separadas por virgula). Inclua o frontend web e,
# para os apps nativos gerados via Capacitor, as origens padrao usadas
# pela WebView (https://localhost no Android/iOS com androidScheme: 'https').
CORS_ORIGIN=http://localhost:5173,https://localhost

# --- Banco de dados (PostgreSQL + pgvector) ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_password
POSTGRES_DB=nexus_ai
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nexus:nexus_password@localhost:5432/nexus_ai?schema=public

# --- Autenticacao (JWT) ---
JWT_SECRET=troque_essa_chave_em_producao
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=troque_essa_chave_tambem
REFRESH_TOKEN_EXPIRES_IN=30d

# --- Modelo de IA (adaptador plugavel) ---
# Provider disponivel: "qwen" | "openai_compatible" | "ollama" | "mock"
#
# Para rodar o Qwen3 8B (open source, Apache 2.0) 100% local via Ollama
# - sem API paga, sem enviar dados para fora da sua rede:
#   1. Instale o Ollama (https://ollama.com) ou use o servico incluso
#      no docker-compose.yml deste projeto (baixa o modelo sozinho).
#   2. AI_PROVIDER=ollama
#   3. AI_BASE_URL=http://localhost:11434/v1
#      (dentro do docker-compose, use http://ollama:11434/v1)
#   4. AI_MODEL_NAME=qwen3:8b
#   5. AI_API_KEY pode ficar vazio (nao e usado pelo Ollama)
#   6. AI_EMBEDDING_MODEL: dimensao diferente do padrao do banco (1536)
#      - veja docs/LOCAL_MODEL.md ANTES de mudar.
#
# Requisito de hardware do Qwen3 8B: ~5.2GB de download (quantizacao
# Q4_K_M) e ~6-8GB de RAM/VRAM livres. Roda sem GPU (CPU-only), porem
# mais devagar. Nao roda no plano free do Render (RAM insuficiente).
AI_PROVIDER=mock
AI_MODEL_NAME=qwen3:8b
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-nexus
AI_EMBEDDING_DIM=1536

# --- Pesquisa na internet (Tool) ---
WEB_SEARCH_PROVIDER=mock
WEB_SEARCH_API_KEY=

# --- Upload de arquivos ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# --- Logs ---
LOG_LEVEL=info

# --- Frontend ---
VITE_API_URL=http://localhost:3333/api/v1
VITE_WS_URL=ws://localhost:3333/api/v1/ws
